# Required: your Radius wallet private key
# Generate one: python -c "from eth_account import Account; print(Account.create().key.hex())"
RADIUS_PRIVATE_KEY=0x...

# Optional: enables natural-language mode (Claude tool-calling)
# Without this, the agent uses simple command routing (balance, send, status, etc.)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override defaults
# AGENT_ID=my-payment-agent
# PORT=6000
# NANDA_REGISTRY_URL=https://successful-communication-production-ac96.up.railway.app
# PUBLIC_URL=https://your-agent.railway.app

# Optional: network configuration (defaults to Radius testnet)
# RADIUS_RPC_URL=https://rpc.radiustech.xyz
# RADIUS_CHAIN_ID=723487
